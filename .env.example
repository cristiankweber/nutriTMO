# PostgreSQL local usado pelo Docker Compose do MVP.
DATABASE_URL="postgresql://nutritmo:nutritmo@localhost:5432/nutritmo?schema=public"

# Segredo local para assinar o cookie de sessao. Troque em cada ambiente.
SESSION_SECRET="troque-esta-chave-local-por-um-valor-longo"

# Pasta local para fotos de refeicao. Uploads reais ficam ignorados pelo Git.
IMAGE_STORAGE_DIR="./storage/images"
